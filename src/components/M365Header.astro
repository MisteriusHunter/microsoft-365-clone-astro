---
/** Header de una sola línea al estilo microsoft.com (Microsoft 365 para individuos) */
const productLinks: { label: string; hasChevron: boolean }[] = [
  { label: "Productos", hasChevron: true },
  { label: "Planes y precios", hasChevron: false },
  { label: "Recursos", hasChevron: true },
  { label: "Soporte técnico", hasChevron: true },
];
---

<header class="w-full border-b border-[#e0e0e0] bg-white">
  <div class="mx-auto flex h-[54px] max-w-[1600px] items-center justify-between px-4 lg:px-6">
    <div class="flex min-w-0 flex-1 items-center gap-5 lg:gap-6">
      <a href="#" class="flex shrink-0 items-center gap-2.5">
        <div class="grid h-[21px] w-[21px] shrink-0 grid-cols-2 gap-px">
          <span class="bg-[#f35325]"></span>
          <span class="bg-[#81bc06]"></span>
          <span class="bg-[#05a6f0]"></span>
          <span class="bg-[#ffba08]"></span>
        </div>
        <span class="border-r border-[#d2d2d2] pr-4 text-[15px] font-normal leading-none text-[#262626]">Microsoft</span>
        <span class="pl-1 text-[15px] font-semibold leading-none text-black">Microsoft 365</span>
      </a>

      <nav class="hidden items-center gap-1 lg:flex" aria-label="Navegación principal">
        {productLinks.map((item) => (
          <a
            href="#"
            class="flex items-center gap-0.5 px-2 py-2 text-[13px] font-normal text-[#262626] hover:underline"
          >
            {item.label}
            {item.hasChevron ? (
              <svg class="mt-px h-3 w-3 text-[#262626]" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
                <path d="M6 8L2 4h8L6 8z" />
              </svg>
            ) : null}
          </a>
        ))}
      </nav>
    </div>

    <div class="flex shrink-0 items-center gap-1 sm:gap-2">
      <a
        href="#"
        class="hidden items-center gap-1.5 px-2 py-2 text-[13px] text-[#262626] hover:underline sm:flex"
      >
        <span>Buscar</span>
        <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <path d="M20 20l-4-4" stroke-linecap="round" />
        </svg>
      </a>

      <!-- ✅ bg-[#0b1f2a] + text-white explícito con !important via style para garantizar override -->
      <a
        href="#"
        style="background-color: #0b1f2a !important; color: #ffffff !important;"
        class="cta-button ml-1 inline-flex items-center rounded-[2px] px-4 py-2 text-[13px] font-semibold hover:opacity-90"
      >
        Probar gratis
      </a>

      <a href="#" class="hidden px-2 py-2 text-[13px] text-[#262626] hover:underline md:inline">
        Iniciar sesión
      </a>

      <a
        href="#"
        class="ml-1 flex h-9 w-9 items-center justify-center rounded-full border border-transparent hover:bg-black/[0.04]"
        aria-label="Cuenta"
      >
        <svg class="h-6 w-6 text-[#262626]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" aria-hidden="true">
          <circle cx="12" cy="8" r="3.5" />
          <path d="M6 19.5c0-3.5 3-5.5 6-5.5s6 2 6 5.5" stroke-linecap="round" />
        </svg>
      </a>
    </div>
  </div>
</header>